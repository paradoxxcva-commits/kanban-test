# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_PASSWORD=supersecretpassword

# ==========================================
# JWT
# ==========================================
# Мин. 32 символа. Используется для генерации ANON_KEY и SERVICE_ROLE_KEY
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters

# API Keys — сгенерируйте из JWT_SECRET (см. README)
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# URLs
# ==========================================
# Публичный URL Supabase (Kong API Gateway) для клиентской части
PUBLIC_SUPABASE_URL=http://localhost:8000

# URL сайта (для auth redirects)
SITE_URL=http://localhost:3000

# ==========================================
# Ports
# ==========================================
APP_PORT=3000
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
